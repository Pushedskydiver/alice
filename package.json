{
  "name": "alice-agents",
  "version": "0.6.0",
  "description": "Find the right AI coding agent for your project",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "alice-agents": "dist/installer/install/install.js"
  },
  "files": [
    "dist/",
    "hooks/",
    "src/commands/",
    "src/workflows/",
    "registry/"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc && tsc-alias",
    "dev": "vitest",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "validate:registry": "node dist/utils/registry/validate.js",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "keywords": [
    "claude-code",
    "ai",
    "coding-agent",
    "slash-commands",
    "cli"
  ],
  "author": "Alex Clapperton",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pushedskydiver/alice.git"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0",
    "zod": "^4.3.6"
  }
}
